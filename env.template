# /etc/cowrie-pusher/env
# Permissions: chmod 600, chown cowrie:cowrie
#
# Generate SHARED_SECRET with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# Then paste the same value into your Worker secret via:
#   wrangler secret put BATHYSPHERE_SECRET

SHARED_SECRET=replace_with_your_generated_secret

INGEST_URL=https://bathysphere.tech/ingest
COWRIE_LOG=/home/cowrie/var/log/cowrie/cowrie.json
STATE_FILE=/var/lib/cowrie-pusher/state.json
POLL_INTERVAL=30
BATCH_SIZE=200
